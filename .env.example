APP_ENV=local
PIPELINE_NAME=sales-analytics
LOG_LEVEL=INFO
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
REPORTS_DIR=reports
PIPELINE_STATE_DIR=data/state
ANALYSIS_DATE_COL=ORDERDATE
ANALYSIS_SALES_COL=SALES
ANALYSIS_DIMENSION_COL=PRODUCTLINE
ANALYSIS_PERIOD=M
ENABLE_PIPELINE_SNAPSHOTS=true
SNAPSHOT_RETENTION_RUNS=
SNAPSHOT_RETENTION_DAYS=
DATA_FRESHNESS_MAX_AGE_DAYS=
DATA_FRESHNESS_REFERENCE_DATE=
STREAMLIT_SERVER_PORT=8501
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
MAX_UPLOAD_MB=40
MAX_UPLOAD_ROWS=250000
MAX_UPLOAD_COLUMNS=50
